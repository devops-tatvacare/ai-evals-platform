# Database (overridden by Docker Compose — only needed for non-Docker development)
DATABASE_URL=postgresql+asyncpg://evals_user:evals_pass@localhost:5432/ai_evals_platform

# File storage
FILE_STORAGE_TYPE=local          # "local" or "azure_blob"
FILE_STORAGE_PATH=./backend/uploads

# Server
API_PORT=8721
CORS_ORIGINS=http://localhost:5173

# --- LLM Providers (BYOK) ---
# Tenant LLM credentials live in platform.tenant_llm_providers and are
# configured per-tenant via Admin → AI Settings. No tenant LLM env vars.
# Fernet key encrypting tenant_llm_providers.api_key_encrypted (REQUIRED).
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# Loss = all tenant LLM API keys become unreadable; back up like JWT_SECRET.
# Must be set BEFORE alembic upgrade head (migration 0047 backfill needs it).
LLM_CREDENTIAL_KEY=

# --- Azure Blob Storage (production only) ---
AZURE_STORAGE_CONNECTION_STRING=
AZURE_STORAGE_CONTAINER=evals-files

# --- Kaira API (adversarial testing against live Kaira — optional) ---
KAIRA_API_URL=
KAIRA_AUTH_TOKEN=
KAIRA_TEST_USER_ID=

# --- Auth / JWT ---
JWT_SECRET=                          # Required — random 64-char hex. Generate with: python -c "import secrets; print(secrets.token_hex(32))"
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=15
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# Bootstrap admin (used only when no users exist in DB)
ADMIN_EMAIL=admin@evals.local
ADMIN_PASSWORD=changeme
ADMIN_TENANT_NAME=Default

# --- LeadSquared API (Inside Sales) ---
LSQ_BASE_URL=https://api-in21.leadsquared.com/v2
LSQ_ACCESS_KEY=
LSQ_SECRET_KEY=

# --- Adversarial test timing ---
ADVERSARIAL_MAX_TURNS=10
ADVERSARIAL_TURN_DELAY=1.5
ADVERSARIAL_CASE_DELAY=3.0

# --- Orchestration integrations (see docs/plans/orchestration/design-spec.md §10.12) ---
WATI_BASE_URL=https://live-mt-server.wati.io
WATI_TENANT_ID=
WATI_API_TOKEN=
WATI_WEBHOOK_SECRET=
BOLNA_BASE_URL=https://api.bolna.ai
BOLNA_API_KEY=
BOLNA_WEBHOOK_SECRET=
BOLNA_FROM_PHONE=
SMS_PROVIDER=
SMS_API_KEY=
SMS_BASE_URL=

# --- Mail (transactional sender) ---
# Single platform mailbox; identity sourced from container env / Azure secretRef.
# Empty SMTP_HOST keeps the subsystem dormant (MailNotConfigured raised at call
# sites). Production must set HOST + USERNAME + PASSWORD + FROM_ADDRESS.
SMTP_HOST=smtp.office365.com
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM_ADDRESS=
SMTP_FROM_DISPLAY=TatvaCare Platform
SMTP_USE_STARTTLS=true
SMTP_TIMEOUT_SECONDS=15
